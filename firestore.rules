rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: Verifica se o usuário está autenticado via Firebase Auth
    function isAuthenticated() {
      return request.auth != null;
    }

    // Regras de Segurança do ERP Carol Ramos Collection (Projeto: carol-ramos-collection-erp)
    
    // Categorias de Produtos
    match /categories/{document=**} {
      allow read, create, update, delete: if isAuthenticated();
    }
    
    // Catálogo de Produtos
    match /products/{document=**} {
      allow read, create, update, delete: if isAuthenticated();
    }
    
    // Kits de Produtos
    match /product_kits/{document=**} {
      allow read, create, update, delete: if isAuthenticated();
    }
    
    // Fornecedores
    match /suppliers/{document=**} {
      allow read, create, update, delete: if isAuthenticated();
    }
    
    // Empresas e Tenants
    match /companies/{document=**} {
      allow read, create, update, delete: if isAuthenticated();
    }

    // Perfis de Usuário (Acesso Restrito ao Próprio Usuário Autenticado)
    match /users/{userId} {
      allow read, write: if isAuthenticated() && request.auth.uid == userId;
    }

    // Logs de Auditoria do Sistema
    match /audit_logs/{document=**} {
      allow read, create: if isAuthenticated();
    }

    // Lixeira Inteligente
    match /recycle_bin/{document=**} {
      allow read, create, update, delete: if isAuthenticated();
    }

    // Coleções de Integrações & Marketplaces (Shopee & Mercado Livre)
    match /marketplace_accounts/{document=**} {
      allow read, create, update, delete: if isAuthenticated();
    }
    match /marketplace_items/{document=**} {
      allow read, create, update, delete: if isAuthenticated();
    }
    match /marketplace_orders/{document=**} {
      allow read, create, update, delete: if isAuthenticated();
    }
    match /marketplace_webhooks_log/{document=**} {
      allow read, create, update, delete: if isAuthenticated();
    }
    match /marketplace_sync_history/{document=**} {
      allow read, create, update, delete: if isAuthenticated();
    }
    match /marketplace_inventory_queue/{document=**} {
      allow read, create, update, delete: if isAuthenticated();
    }
  }
}
